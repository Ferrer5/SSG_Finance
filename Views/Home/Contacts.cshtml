@model MyMvcApp.Models.ContactViewModel
@{
    ViewData["Title"] = "Contacts - SSG Portal";
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>@ViewData["Title"]</title>
<link rel="icon" type="image/png" href="/images/favicon.png" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
<style>
:root {
  --green:      #27a744;
  --green-dark: #218c3a;
  --green-deep: #1a6e2e;
  --white:      #ffffff;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  font-family: 'Inter', 'Segoe UI', sans-serif;
  min-height: 100vh;
  background: #0a280e;
  color: var(--white);
}

#heroBg {
  position: fixed;
  inset: 0;
  background: url('/images/CtuGinatilan.jpg') no-repeat center / cover;
  filter: blur(3px);
  transform: scale(1.08);
  z-index: 0;
  transition: filter 0.9s ease, transform 0.9s ease;
}

#heroOverlay {
  position: fixed;
  inset: 0;
  background:
    linear-gradient(to bottom,
      rgba(20,60,30,0.82) 0%,
      rgba(10,40,20,0.52) 40%,
      rgba(10,40,20,0.52) 65%,
      rgba(20,60,30,0.80) 100%);
  z-index: 1;
  transition: opacity 0.9s ease;
}

/* When login is open, darken overlay slightly */
body.login-open #heroOverlay {
  opacity: 0.75;
}

@@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-16px); }
  to   { opacity: 1; transform: translateY(0); }
}

@@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.top-accent {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--green), transparent);
  z-index: 1000;
}

/* NAVBAR */
.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28px 72px 24px;
  border-bottom: 1px solid rgba(255,255,255,0.12);
  position: relative;
  /* Above .main-section (also z-index 2) so fixed mobile .nav-links receives clicks */
  z-index: 15;
}

.logo { display:flex; align-items:center; gap:12px; }

.logo img {
  width:48px; height:48px;
  border-radius:50%;
  border:2px solid var(--green);
  object-fit:cover;
  box-shadow:0 0 14px rgba(39,167,68,0.45);
}

.logo-text { display:flex; flex-direction:column; line-height:1.15; }
.logo-text .brand { font-size:17px; font-weight:700; color:var(--white); }
.logo-text .sub   {
  font-size:10px; letter-spacing:0.14em;
  color:rgba(39,167,68,0.9); text-transform:uppercase; font-weight:500;
}

.nav-links { display: flex; align-items: center; gap: 4px; }

.nav-links a {
  text-decoration: none;
  color: rgba(255,255,255,0.82);
  font-size: 14px;
  font-weight: 500;
  padding: 10px 18px;
  border-radius: 8px;
  position: relative;
  cursor: pointer;
  transition: color 0.25s ease, background 0.25s ease;
}

.nav-links a::after {
  content: '';
  position: absolute;
  bottom: 6px;
  left: 50%;
  transform: translateX(-50%) scaleX(0);
  width: 56%;
  height: 2px;
  background: var(--green);
  border-radius: 2px;
  transition: transform 0.25s ease;
}

.nav-links a:hover { background: rgba(255,255,255,0.08); }
.nav-links a:hover:not(.active) { color: var(--white); }
.nav-links a:hover::after { transform: translateX(-50%) scaleX(1); }

.nav-links a.active {
  color: var(--green);
  font-weight: 600;
}
.nav-links a.active::after { transform: translateX(-50%) scaleX(1); }
.nav-links a.active:hover { color: var(--green); }

/* Burger Menu */
.burger-menu {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 44px;
  height: 44px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 8px;
  border-radius: 8px;
  transition: background 0.2s ease;
}

.burger-menu:hover { background: rgba(255,255,255,0.1); }

.burger-menu span {
  display: block;
  width: 24px;
  height: 2.5px;
  background: rgba(255,255,255,0.9);
  border-radius: 2px;
  transition: all 0.3s ease;
}

.burger-menu.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.burger-menu.active span:nth-child(2) { opacity: 0; }
.burger-menu.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

.clock {
  font-size:13px; font-weight:600; letter-spacing:0.06em;
  color:rgba(255,255,255,0.75);
  background:rgba(39,167,68,0.15);
  border:1px solid rgba(39,167,68,0.35);
  padding:7px 14px; border-radius:8px;
  backdrop-filter:blur(8px);
  min-width:130px; text-align:center;
}

/* MAIN CONTENT */
.main-content {
  position: relative;
  z-index: 10;
  padding: 120px 40px 60px;
  max-width: 900px;
  margin: 0 auto;
}

.page-title {
  font-size: 42px;
  font-weight: 700;
  margin-bottom: 30px;
  background: linear-gradient(90deg, #ffffff 0%, #a0ffc0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  opacity: 0;
  animation: fadeUp 0.72s 0.18s cubic-bezier(0.4,0,0.2,1) forwards;
}

.content-card {
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 16px;
  padding: 32px;
  margin-bottom: 24px;
  opacity: 0;
  animation: fadeUp 0.72s cubic-bezier(0.4,0,0.2,1) forwards;
}

.main-content > .content-card:nth-of-type(1) { animation-delay: 0.28s; }
.main-content > .content-card:nth-of-type(2) { animation-delay: 0.40s; }
.main-content > .content-card:nth-of-type(3) { animation-delay: 0.52s; }
.main-content > .content-card:nth-of-type(4) { animation-delay: 0.64s; }
.main-content > .content-card:nth-of-type(5) { animation-delay: 0.76s; }

.content-card h2 {
  font-size: 22px;
  font-weight: 600;
  margin-bottom: 16px;
  color: var(--green);
}

.content-card p {
  font-size: 15px;
  line-height: 1.7;
  color: rgba(255,255,255,0.85);
  margin-bottom: 12px;
}

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.contact-item:last-child { border-bottom: none; }

.contact-icon {
  width: 48px;
  height: 48px;
  background: rgba(39,167,68,0.2);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: var(--green);
  flex-shrink: 0;
}

.contact-info h3 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 4px;
  color: var(--white);
}

.contact-info p, .contact-info a {
  font-size: 14px;
  color: rgba(255,255,255,0.75);
  text-decoration: none;
}

.contact-info a:hover { color: var(--green); }

@@media (prefers-reduced-motion: reduce) {
  .navbar, .page-title, .content-card {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
}

/* Mobile Responsive */
@@media (max-width: 640px) {
  .burger-menu { display: flex; }
  
  .nav-links {
    position: fixed;
    top: 70px;
    right: 20px;
    flex-direction: column;
    gap: 0;
    background: rgba(10,25,14,0.98);
    backdrop-filter: blur(20px);
    padding: 12px 8px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    min-width: 180px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px) scale(0.95);
    transition: all 0.25s ease;
    z-index: 1000;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }
  
  .nav-links.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }
  
  .nav-links a {
    display: block;
    padding: 12px 20px;
    font-size: 14px;
    border-radius: 8px;
    white-space: nowrap;
  }

  .nav-links a::after { display: none; }
  
  .nav-links a:hover { background: rgba(255,255,255,0.08); }
  
  .navbar { padding: 14px 20px; }
  .clock { display: none; }
  .main-content { padding: 100px 20px 40px; }
  .page-title { font-size: 32px; }
  .content-card { padding: 24px; }
  .contact-item { gap: 12px; }
  .contact-icon { width: 40px; height: 40px; font-size: 20px; }
}

/* Hide scrollbar while keeping scrolling functionality */
html::-webkit-scrollbar { display: none; }
html { -ms-overflow-style: none; overflow: -moz-scrollbars-none; }
body { scrollbar-width: none; }
</style>
</head>
<body>

<div class="top-accent"></div>
<div id="heroBg"></div>
<div id="heroOverlay"></div>

<nav class="navbar">
  <div class="logo">
    <img src="/images/logo.png" alt="SSG Logo">
    <div class="logo-text">
      <span class="brand">SSG Finance</span>
      <span class="sub">Management System</span>
    </div>
  </div>

  <button class="burger-menu" onclick="toggleMobileNav()" aria-label="Toggle navigation">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <div class="nav-links" id="mobileNav">
    <a href="@Url.Action("Index", "Home")">Home</a>
    <a href="@Url.Action("About", "Home")">About</a>
    <a href="@Url.Action("Contacts", "Home")" class="active">Contacts</a>
    <a href="@Url.Action("Login", "Home")">Login</a>
  </div>

  <div id="clock" class="clock"></div>
</nav>

<main class="main-content">
  <h1 class="page-title">Contact Us</h1>
  
  <div class="content-card">
    <h2>Get in Touch</h2>
    <p>Reach the Student Government through any of the channels below.</p>

    @foreach (var t in Model.Treasurers)
    {
      <div class="contact-item">
        <div class="contact-icon">
          <ion-icon name="person-outline"></ion-icon>
        </div>
        <div class="contact-info">
          <h3>@t.Name <span style="font-weight:500;color:var(--green);font-size:13px">· @t.Role</span></h3>
          <a href="mailto:@t.Email">@t.Email</a>
        </div>
      </div>
    }
    @if (Model.Treasurers.Count == 0)
    {
      <div class="contact-item">
        <div class="contact-icon">
          <ion-icon name="mail-outline"></ion-icon>
        </div>
        <div class="contact-info">
          <h3>Treasurer</h3>
          <p>No treasurer contact is available right now — please use the form below or reach us on Facebook.</p>
        </div>
      </div>
    }

    <div class="contact-item">
      <div class="contact-icon">
        <ion-icon name="logo-facebook"></ion-icon>
      </div>
      <div class="contact-info">
        <h3>CTU Ginatilan Support Group</h3>
        <a href="https://www.facebook.com/share/g/1Bn9obDsqg/" target="_blank" rel="noopener noreferrer">CTU Ginatilan Support Group</a>
      </div>
    </div>

    <div class="contact-item">
      <div class="contact-icon">
        <ion-icon name="logo-facebook"></ion-icon>
      </div>
      <div class="contact-info">
        <h3>CTU Ginatilan - Supreme Student Government</h3>
        <a href="https://www.facebook.com/profile.php?id=61580269426838" target="_blank" rel="noopener noreferrer">CTU Ginatilan - Supreme Student Government</a>
      </div>
    </div>

    <div class="contact-item">
      <div class="contact-icon">
        <ion-icon name="location-outline"></ion-icon>
      </div>
      <div class="contact-info">
        <h3>Location</h3>
        <p>Cebu Technological University - Ginatilan Campus<br>San Roque, Ginatilan, Cebu, Philippines</p>
      </div>
    </div>
  </div>

</main>

<footer style="position:relative;z-index:10;text-align:center;padding:20px;margin-top:8px;border-top:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.45);font-size:12px;letter-spacing:0.04em;">
  © @DateTime.Now.Year BSIT Students<button type="button" class="dev-credit-btn" onclick="openDevModal()" aria-label="About the developers" title="About the developers"><ion-icon name="help-circle-outline"></ion-icon></button> · Supreme Student Government — CTU Ginatilan
</footer>

<script>
function toggleMobileNav() {
  const burger = document.querySelector('.burger-menu');
  const nav = document.getElementById('mobileNav');
  burger.classList.toggle('active');
  nav.classList.toggle('active');
}

// Close mobile nav when clicking outside
document.addEventListener('click', function(e) {
  const nav = document.getElementById('mobileNav');
  const burger = document.querySelector('.burger-menu');
  if (nav && burger && nav.classList.contains('active')) {
    if (!nav.contains(e.target) && !burger.contains(e.target)) {
      burger.classList.remove('active');
      nav.classList.remove('active');
    }
  }
});

function updateClock() {
  const now = new Date();
  let h = now.getHours();
  const m = String(now.getMinutes()).padStart(2, '0');
  const s = String(now.getSeconds()).padStart(2, '0');
  const ap = h >= 12 ? 'PM' : 'AM';
  h = h % 12 || 12;
  const clock = document.getElementById('clock');
  if (clock) {
    clock.textContent = `${h}:${m}:${s} ${ap}`;
  }
}
setInterval(updateClock, 1000);
updateClock();
</script>

@await Html.PartialAsync("_DeveloperModal")
</body>
</html>
