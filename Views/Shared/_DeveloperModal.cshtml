@*
    Developer/contributors modal for the public pages.
    Triggered by the "?" icon next to "BSIT Students" in the footer.
    The contributors are intentionally kept anonymous.
*@
<div id="devModal" class="dev-modal" onclick="if(event.target===this)closeDevModal()">
  <div class="dev-modal-card" role="dialog" aria-modal="true" aria-labelledby="devModalTitle">
    <button class="dev-modal-close" onclick="closeDevModal()" aria-label="Close">✕</button>
    <div class="dev-modal-icon"><ion-icon name="people-outline"></ion-icon></div>
    <h3 id="devModalTitle">About the Developers</h3>
    <p>This system was designed and developed by BSIT students of CTU&nbsp;Ginatilan. At the team's request, the contributors remain anonymous.</p>
  </div>
</div>

<style>
.dev-credit-btn{
  display:inline-flex; align-items:center; justify-content:center;
  background:none; border:none; padding:0; margin:0 0 0 4px;
  color:inherit; cursor:pointer; vertical-align:-2px; opacity:.7; font:inherit;
}
.dev-credit-btn ion-icon{ font-size:14px; }
.dev-credit-btn:hover{ opacity:1; color:#27a744; }

.dev-modal{
  position:fixed; inset:0; z-index:2000; display:none;
  align-items:center; justify-content:center; padding:20px;
  background:rgba(0,0,0,.6); backdrop-filter:blur(4px);
}
.dev-modal.open{ display:flex; }
.dev-modal-card{
  position:relative; max-width:380px; width:100%;
  background:#0e2a14; border:1px solid rgba(255,255,255,.12);
  border-radius:16px; padding:30px 26px 26px; text-align:center; color:#fff;
  box-shadow:0 20px 50px rgba(0,0,0,.5); animation:devPop .25s ease;
}
@@keyframes devPop{ from{ opacity:0; transform:translateY(10px) scale(.97); } to{ opacity:1; transform:none; } }
.dev-modal-icon{
  width:54px; height:54px; margin:0 auto 14px; border-radius:50%;
  display:flex; align-items:center; justify-content:center; font-size:28px;
  background:rgba(39,167,68,.18); border:1px solid rgba(39,167,68,.4); color:#5fdd8e;
}
.dev-modal-card h3{ font-size:18px; font-weight:700; margin:0 0 8px; }
.dev-modal-card p{ font-size:13.5px; line-height:1.7; color:rgba(255,255,255,.8); margin:0; }
.dev-modal-close{
  position:absolute; top:12px; right:14px; width:28px; height:28px; border:none;
  border-radius:7px; cursor:pointer; font-size:14px; line-height:1; font-family:inherit;
  background:rgba(255,255,255,.08); color:rgba(255,255,255,.7);
}
.dev-modal-close:hover{ background:rgba(239,68,68,.15); color:#f87171; }
</style>

<script>
function openDevModal(){ var m=document.getElementById('devModal'); if(m) m.classList.add('open'); }
function closeDevModal(){ var m=document.getElementById('devModal'); if(m) m.classList.remove('open'); }
document.addEventListener('keydown', function(e){ if(e.key === 'Escape') closeDevModal(); });
</script>
